# dev shell rc — sourced by `make sh`
[ -f ~/.bashrc ] && . ~/.bashrc

# PS1 = [parent_dir/current_dir] (git_branch) $   — recomputed every return
_set_ps1() {
  local p=${PWD%/*}; p=${p##*/}
  local c=${PWD##*/}
  local b
  if b=$(git symbolic-ref --short HEAD 2>/dev/null); then
    b=" \[\033[1;36m\](${b})\[\033[0m\]"
  else
    b=""
  fi
  PS1="\[\033[1;33m\][${p}/${c}]\[\033[0m\]${b} $ "
}
PROMPT_COMMAND=_set_ps1
